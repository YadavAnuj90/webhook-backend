# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
PUBLIC_API_URL=http://localhost:3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/webhookos

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_REFRESH_EXPIRES_IN=7d

# ─── Razorpay (Billing) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Metrics Export ───────────────────────────────────────────────────────────
METRICS_PREFIX=webhook_
DATADOG_API_KEY=                        # Optional: your Datadog API key
NEW_RELIC_API_KEY=                      # Optional: your New Relic ingest key
NEW_RELIC_ACCOUNT_ID=                   # Optional: your New Relic account ID

# ─── Circuit Breaker ──────────────────────────────────────────────────────────
CIRCUIT_BREAKER_TIMEOUT=10000

# ─── FEATURE 5: Payload Encryption at Rest ────────────────────────────────
# Optional: 32-character encryption key for at-rest encryption. Leave blank to disable.
PAYLOAD_ENCRYPTION_KEY=

# ─── AI Features ──────────────────────────────────────────────────────────────
# Powers: AI Debugger, Schema Generator, DLQ Triage, PII Detector
# Priority: DeepSeek is used first if set; Gemini is the fallback.
# Set at least ONE key. DeepSeek recommended (faster JSON mode, lower cost).
#
# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-7ca520aa8d4b4ea5a0fc3977948189b3
#
# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDNByaoDQVcChJVhcFNZZOgKtAxPr2RjYc
