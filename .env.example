# ═══════════════════════════════════════════════════════
# WebhookOS Backend — Environment Configuration
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════════════

# ── Core (required) ──────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# ── MongoDB (required) ──────────────────────────────
MONGODB_URI=mongodb://localhost:27017/webhookos

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (required — use strong random strings) ──────
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Razorpay Payments (optional) ────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email / SMTP (optional) ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── Google OAuth (optional) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── OpenAI / AI features (optional) ─────────────────
OPENAI_API_KEY=

# ── Delivery Tuning ─────────────────────────────────
CIRCUIT_BREAKER_TIMEOUT=10000
ENDPOINT_CACHE_TTL_S=30

# ── Public API URL (for tunnel feature) ─────────────
PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Payload Encryption (optional) ───────────────────
PAYLOAD_ENCRYPTION_KEY=
